{
  "name": "unraid-codex-media-issue-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Human-in-the-loop media issue triage agent for Plex and Seerr-family reports.",
  "bin": {
    "media-issue-agent": "./src/cli.js"
  },
  "scripts": {
    "check": "node --check src/*.js test/*.js",
    "test": "node test/run-tests.js && node test/comprehensive-tests.js && node test/review-regressions.js && node test/feedback-loop-tests.js",
    "test:coverage": "c8 --all --include='src/*.js' --reporter=text-summary --reporter=lcov --check-coverage --statements=88 --branches=65 --functions=85 --lines=88 npm test",
    "test:comprehensive": "node test/comprehensive-tests.js",
    "test:web": "node test/web-e2e.js",
    "sil": "node test/sil-runner.js",
    "start": "node src/cli.js serve"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "c8": "^10.1.3"
  }
}
