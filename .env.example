# Development image names.
CODEX_TERMINAL_IMAGE=ghcr.io/shepemer/unraid-codex-terminal:dev
UNRAID_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-unraid-mcp:1.2.4-dev
MEDIA_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-media-mcp:dev
UTILITIES_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-utilities-mcp:dev
ISSUE_AGENT_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-media-issue-agent:dev

# SSH into codex-terminal.
CODEX_SSH_PORT=2222
SSH_AUTHORIZED_KEYS=
SSH_PASSWORD_LOGIN=false
SSH_PASSWORD=
SSH_PASSWORD_HASH=

# Web terminal into the same Codex workspace.
# WEBUI_PASSWORD is required when WEBUI_AUTH=true.
CODEX_WEBUI_PORT=7681
WEBUI_ENABLED=true
WEBUI_AUTH=true
WEBUI_USERNAME=codex
WEBUI_PASSWORD=
WEBUI_MAX_CLIENTS=5
WEBUI_TMUX_SESSION=codex
WEBUI_LOG_LEVEL=1
AUTO_LAUNCH_CODEX=true
CODEX_WEBUI_BYPASS_APPROVALS=true
CODEX_UPDATE_ON_START=true
CODEX_NPM_VERSION=latest
CODEX_UPDATE_ON_START_TIMEOUT=180

# Optional media/download path diagnostics inside codex-terminal.
# If you enable the matching compose volume lines, media-path-check can map
# service paths like /downloads/foo to mounted inspection paths. Keep downloads
# read-only unless you intentionally want shell-side archive extraction.
CODEX_MEDIA_PATH_MAPS=
CODEX_MEDIA_LIBRARY_DIR=/mnt/user/media
CODEX_DOWNLOADS_DIR=/mnt/user/downloads

# Shared MCP client auth token. Generate with:
# openssl rand -hex 32
UNRAID_MCP_BEARER_TOKEN=

# Unraid GraphQL API. Keep the API key only on the MCP sidecar.
UNRAID_API_URL=http://tower.local/graphql
UNRAID_API_KEY=
UNRAID_MCP_TRANSPORT=streamable-http
UNRAID_MCP_HOST=0.0.0.0
UNRAID_MCP_PORT=6970

# Optional media MCP sidecar. Enable with:
# docker compose --profile media up -d media-mcp
MEDIA_MCP_URL=http://media-mcp:6971/mcp
MEDIA_MCP_BEARER_TOKEN=
MEDIA_MCP_HOST=0.0.0.0
MEDIA_MCP_PORT=6971
MEDIA_MCP_REQUEST_TIMEOUT_MS=30000
MEDIA_MCP_DOWNLOADS_DIR=/mnt/user/downloads
MEDIA_MCP_MEDIA_DIR=/mnt/user/media
MEDIA_MCP_MEDIA_ROOTS=/mnt/unraid/media
MEDIA_MCP_PATH_MAPS=/downloads=/mnt/unraid/downloads

# Configure only the media apps Codex should manage.
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=
PLEX_URL=
PLEX_TOKEN=
TAUTULLI_URL=
TAUTULLI_API_KEY=
TRACEARR_URL=
TRACEARR_API_KEY=
BAZARR_URL=
BAZARR_API_KEY=
PROWLARR_URL=
PROWLARR_API_KEY=
QBITTORRENT_URL=
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
NZBGET_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=
SEERR_URL=
SEERR_API_KEY=

# Optional human-in-the-loop media issue agent. Enable with:
# docker compose --profile issue-agent up -d media-issue-agent
# Populate ISSUE_AGENT_CODEX_HOME by running Codex login with ChatGPT auth
# inside the container, or by copying a trusted Codex auth cache. Do not use
# OPENAI_API_KEY or CODEX_API_KEY; the agent refuses API-key auth.
ISSUE_AGENT_MEDIA_MCP_URL=http://media-mcp:6971/mcp
ISSUE_AGENT_MEDIA_MCP_BEARER_TOKEN=
ISSUE_AGENT_DB_PATH=/state/media-issue-agent.sqlite
ISSUE_AGENT_LOG_PATH=/state/media-issue-agent.log
ISSUE_AGENT_REPAIR_WORKSPACE_ROOT=/state/repair-workspaces
ISSUE_AGENT_REPAIR_CONTEXT=
ISSUE_AGENT_POLL_INTERVAL_SECONDS=300
ISSUE_AGENT_SNAPSHOT_RETENTION=200
ISSUE_AGENT_CODEX_MODEL=gpt-5.5
ISSUE_AGENT_CODEX_REASONING_EFFORT=xhigh
ISSUE_AGENT_CODEX_FAST_MODE=true
ISSUE_AGENT_CODEX_SERVICE_TIER=fast
ISSUE_AGENT_CODEX_REPAIR_TIMEOUT_MS=14400000
ISSUE_AGENT_MCP_REQUEST_TIMEOUT_MS=300000
ISSUE_AGENT_RECOVER_STALE_RUN_SECONDS=120
ISSUE_AGENT_CODEX_ENV_ALLOWLIST=
ISSUE_AGENT_APPROVAL_BACKEND=web
ISSUE_AGENT_WEBUI_PORT=6983
ISSUE_AGENT_WEB_ENABLED=true
ISSUE_AGENT_WEB_HOST=0.0.0.0
ISSUE_AGENT_WEB_USERNAME=operator
ISSUE_AGENT_WEB_PASSWORD=
ISSUE_AGENT_DISCORD_BOT_TOKEN=
ISSUE_AGENT_DISCORD_CHANNEL_ID=
ISSUE_AGENT_PUSHOVER_APP_TOKEN=
ISSUE_AGENT_PUSHOVER_USER_KEY=
ISSUE_AGENT_STATE_DIR=./data/media-issue-agent/state
ISSUE_AGENT_CODEX_HOME=./data/media-issue-agent/codex

# Optional utilities MCP sidecar. Enable with:
# docker compose --profile utilities up -d utilities-mcp
UTILITIES_MCP_URL=http://utilities-mcp:6972/mcp
UTILITIES_MCP_BEARER_TOKEN=
UTILITIES_MCP_HOST=0.0.0.0
UTILITIES_MCP_PORT=6972
UTILITIES_MCP_REQUEST_TIMEOUT_MS=30000

# Configure only the utility services Codex should inspect.
SCRUTINY_URL=
SCRUTINY_BASE_PATH=

# Local development bind mounts.
CODEX_CONFIG_DIR=./data/codex-terminal
UNRAID_MCP_STATE_DIR=./data/unraid-mcp/state
UNRAID_MCP_LOG_DIR=./data/unraid-mcp/logs
UNRAID_MCP_BACKUP_DIR=./data/unraid-mcp/backups
