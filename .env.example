# Development image names.
CODEX_TERMINAL_IMAGE=ghcr.io/shepemer/unraid-codex-terminal:dev
UNRAID_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-unraid-mcp:1.2.4-dev
MEDIA_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-media-mcp:dev
UTILITIES_MCP_IMAGE=ghcr.io/shepemer/unraid-codex-terminal-utilities-mcp:dev

# SSH into codex-terminal.
CODEX_SSH_PORT=2222
SSH_AUTHORIZED_KEYS=
SSH_PASSWORD_LOGIN=false
SSH_PASSWORD=
SSH_PASSWORD_HASH=

# Web terminal into the same Codex workspace.
# WEBUI_PASSWORD is required when WEBUI_AUTH=true.
CODEX_WEBUI_PORT=7681
WEBUI_ENABLED=true
WEBUI_AUTH=true
WEBUI_USERNAME=codex
WEBUI_PASSWORD=
WEBUI_MAX_CLIENTS=5
WEBUI_TMUX_SESSION=codex
WEBUI_LOG_LEVEL=1
AUTO_LAUNCH_CODEX=true
CODEX_WEBUI_BYPASS_APPROVALS=true
CODEX_UPDATE_ON_START=true
CODEX_NPM_VERSION=latest
CODEX_UPDATE_ON_START_TIMEOUT=180

# Shared MCP client auth token. Generate with:
# openssl rand -hex 32
UNRAID_MCP_BEARER_TOKEN=

# Unraid GraphQL API. Keep the API key only on the MCP sidecar.
UNRAID_API_URL=http://tower.local/graphql
UNRAID_API_KEY=
UNRAID_MCP_TRANSPORT=streamable-http
UNRAID_MCP_HOST=0.0.0.0
UNRAID_MCP_PORT=6970

# Optional media MCP sidecar. Enable with:
# docker compose --profile media up -d media-mcp
MEDIA_MCP_URL=http://media-mcp:6971/mcp
MEDIA_MCP_BEARER_TOKEN=
MEDIA_MCP_HOST=0.0.0.0
MEDIA_MCP_PORT=6971
MEDIA_MCP_REQUEST_TIMEOUT_MS=30000

# Configure only the media apps Codex should manage.
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=
PLEX_URL=
PLEX_TOKEN=
BAZARR_URL=
BAZARR_API_KEY=
PROWLARR_URL=
PROWLARR_API_KEY=
QBITTORRENT_URL=
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
NZBGET_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=
SEERR_URL=
SEERR_API_KEY=

# Optional utilities MCP sidecar. Enable with:
# docker compose --profile utilities up -d utilities-mcp
UTILITIES_MCP_URL=http://utilities-mcp:6972/mcp
UTILITIES_MCP_BEARER_TOKEN=
UTILITIES_MCP_HOST=0.0.0.0
UTILITIES_MCP_PORT=6972
UTILITIES_MCP_REQUEST_TIMEOUT_MS=30000

# Configure only the utility services Codex should inspect.
SCRUTINY_URL=
SCRUTINY_BASE_PATH=

# Local development bind mounts.
CODEX_CONFIG_DIR=./data/codex-terminal
UNRAID_MCP_STATE_DIR=./data/unraid-mcp/state
UNRAID_MCP_LOG_DIR=./data/unraid-mcp/logs
UNRAID_MCP_BACKUP_DIR=./data/unraid-mcp/backups
